{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Visual E2E Test",
  "version": "1.0.0",
  "identifier": "com.visual-e2e-test.app",
  "build": {
    "beforeDevCommand": "npm run build:server && node scripts/dev/tauri-web.mjs",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:client",
    "frontendDist": "../workspace/web/dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:* http://localhost:* ws://localhost:* data: blob: 'unsafe-inline' 'unsafe-eval'",
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/app/",
      "resources/node/"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  },
  "plugins": {}
}
