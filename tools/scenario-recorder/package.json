{
  "name": "@visual-e2e-test/tool-scenario-recorder",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p server/tsconfig.json && cp server/src/browser-hooks.inject.js server/dist/",
    "build:web": "vite build --config web/vite.config.ts",
    "typecheck": "tsc -p server/tsconfig.json --noEmit && tsc -p web/tsconfig.json --noEmit",
    "test": "node --import tsx --test server/src/normalizer.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.3.0",
    "fastify": "^5.2.1",
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "@ant-design/icons": "^5.6.1",
    "@tanstack/react-query": "^5.66.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "antd": "^5.23.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^6.0.11"
  }
}
